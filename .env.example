# Login passwords are hardcoded in backend/src/auth.ts (ADMIN_PASSWORD, USER_PASSWORD).

# Google Gemini API key (required for image processing)
GEMINI_API_KEY=your-gemini-api-key

# Google Drive: use ONE of the two options below.
# Option A – Service account: path to JSON key file
# GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/drive-service-account.json
# Option B – OAuth (client ID + secret + refresh token). Get the refresh token once via backend/scripts/get-drive-refresh-token.js
GOOGLE_DRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your-client-secret
GOOGLE_DRIVE_REFRESH_TOKEN=your-refresh-token

# Root folder ID in Google Drive where listing subfolders will be created (required)
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-root-folder-id

# Server port (default 3000)
PORT=3000

# Optional: ScraperAPI proxy (on by default when set; new IP each session). When credits run out, proxy is auto-disabled and scraping continues without proxy. To re-enable after adding credits, delete backend/.scraperapi_no_credits .
# SCRAPING_PROXY_API_KEY=your-scraperapi-key
#
# Or use a custom proxy URL (overrides API key if both set):
# SCRAPING_PROXY_URL=http://user:pass@proxy.example.com:8080

# Optional: Node env
NODE_ENV=production
