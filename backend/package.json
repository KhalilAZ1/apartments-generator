{
  "name": "listing-image-processor-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); const p=require('path'); const d=p.join('dist','data'); fs.mkdirSync(d,{recursive:true}); fs.copyFileSync(p.join('src','data','german-cities-rent.json'), p.join(d,'german-cities-rent.json'));\"",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "sharp": "^0.34.3",
    "undici": "^6.0.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "google-auth-library": "^9.4.1",
    "googleapis": "^128.0.0",
    "@google/generative-ai": "^0.21.0",
    "playwright": "^1.40.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
